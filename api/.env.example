APP_NAME=bmt-saas
APP_ENV=development
APP_VERSION=1.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s

DATABASE_URL=postgres://postgres:postgres@localhost:5432/bmt_saas_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

REDIS_URL=redis://localhost:6379/0
REDIS_TTL=5m

JWT_ACCESS_SECRET=your-access-secret-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bmt-saas
MINIO_USE_SSL=false

ASYNQ_CONCURRENCY=10

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENV=sandbox

DEVELOPER_TOKEN=dev-secret-token-change-in-production
