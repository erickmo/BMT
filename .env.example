# ══════════════════════════════════════════════════════════════════════════════
# BMT SaaS — Environment Variables
# Salin file ini ke .env dan isi nilainya sebelum menjalankan Docker
# JANGAN commit file .env ke git
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_VERSION=1.0.0
API_PORT=8080

# ── Database (PostgreSQL External) ───────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname?sslmode=disable
# Host bisa berupa IP server, domain, atau host.docker.internal (jika local)
DATABASE_URL=postgres://bmt_user:ganti_password_kuat@192.168.1.100:5432/bmt_saas_db?sslmode=disable

# ── Redis (internal Docker) ───────────────────────────────────────────────────
# Tidak perlu diubah jika pakai Redis dari docker-compose ini
# REDIS_URL diset otomatis ke redis://redis:6379 di docker-compose

# ── JWT (wajib diisi dengan string acak panjang >= 32 karakter) ───────────────
JWT_ACCESS_SECRET=ganti-dengan-string-acak-minimal-32-karakter-access
JWT_REFRESH_SECRET=ganti-dengan-string-acak-minimal-32-karakter-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── MinIO (Object Storage) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=ganti_password_minio_kuat
MINIO_BUCKET=bmt-files
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Developer Token (untuk endpoint /dev/*) ───────────────────────────────────
DEVELOPER_TOKEN=ganti-dengan-token-rahasia-developer

# ── Midtrans Payment Gateway ──────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_ENV=sandbox
# Untuk production: MIDTRANS_ENV=production dan ganti key di atas

# ── Asynq Worker ──────────────────────────────────────────────────────────────
ASYNQ_CONCURRENCY=10

# ── Flutter Web Apps ──────────────────────────────────────────────────────────
# URL API yang dapat diakses dari browser client (bukan dari dalam Docker)
# Gunakan domain atau IP publik server, BUKAN nama service Docker
API_BASE_URL=http://your-server-ip-or-domain:8080

# Port untuk masing-masing web app
WEB_MANAGEMENT_PORT=3001
WEB_DEVELOPER_PORT=3002
WEB_PONDOK_PORT=3003
